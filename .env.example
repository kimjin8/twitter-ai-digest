# === Firestore ===
# For local development: paste your Firebase service account JSON as a single line.
# On Cloud Run: leave unset — Application Default Credentials are used automatically.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# === X (Twitter) API ===
# Primary: TwitterAPI.io (Cost-optimized)
# Get your API key from https://twitterapi.io
TWITTERAPI_IO_KEY=your-twitterapi-io-key-here
# Fallback: Official X API v2 (Optional)
X_BEARER_TOKEN=your-bearer-token-here

# === Gemini AI ===
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# === Email Recipient ===
# The email address that will receive the daily digest
RECIPIENT_EMAIL=hongkimjin@gmail.com
# === Optimization ===
# Filtering at the source (API Level) saves TwitterAPI.io credits
# Set to 5-10 for high signal, 0 to fetch move raw tweets
MIN_FAVES_FILTER=5
# === Twitter Usernames ===
# Comma-separated Twitter usernames to monitor (no @ prefix)
